NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
# Optional: overrides the frontend dev proxy target. Defaults to http://localhost:${PORT}.
# API_PROXY_TARGET=http://localhost:3000
# Optional: forces frontend API requests to a specific backend URL.
# In dev, Vite defaults this to http://127.0.0.1:${PORT}; production builds default to same-origin.
# API_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

DB_HOST=localhost
DB_PORT=3306
DB_USER=contacts
DB_PASSWORD=contacts
DB_NAME=contacts
DB_SYNCHRONIZE=true
DB_CONNECT_RETRIES=15
DB_CONNECT_RETRY_DELAY_MS=2000

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=2h

ADMIN_NAME=admin
ADMIN_PASSWORD=admin123
